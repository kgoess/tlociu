<div id="content" class="entry-detail">
    <div class="entry-actions">
        <a href="<% request.uri_for('/entry/'_ entry.id _ '/update') %>">Update</a>
        <a class="danger" href="<% request.uri_for('/entry/'_ entry.id _ '/delete') %>">Delete</a>
    </div>
    <h1><% entry.title | html_entity %></h1>
    <% IF movie.tagline %>
    <p class="tagline"><% movie.tagline %></p>
    <% END %>

    <div class="detail-body">
        <img class="poster" src="<% base_url _ 'w500' _ movie.poster | html %>" alt="<% entry.title | html %> poster">
        <div class="detail-text">
            <p><% movie.overview %></p>
            <p><a class="button" href="<% trailer %>">▶ Play Trailer</a></p>

            <h3>Watchlist notes <em>(<% entry.date_added.strftime("%a, %b %e, %Y") | html %>)</em></h3>
            <p><% entry.watchlist_notes | html_entity | html_line_break %></p>

            <h3>Watched notes</h3>
            <p><% entry.watched_notes | html_entity | html_line_break %></p>

            <% IF entry.date_watched %>
            <p class="detail-meta">Watched on <% entry.date_watched.strftime("%a, %b %e, %Y") %></p>
            <% END %>
            <p class="detail-meta">Entry created: <% entry.created_at.ymd | html_entity %></p>
        </div>
    </div>

<% ELSE %>
    <p>Invalid entry.</p>
<% END %>
</div>
