<div id="delete">
    <form method="post" action="<% request.uri_for('/entry/' _ id _ '/delete') %>">
        <p>Delete entry for "<% title | html %>" #<% id %>. Are you sure?</p>
        <div class="field inline">
            <input type="radio" id="yes" name="delete_it" value="yes">
            <label for="yes">Yes</label>
            &nbsp;
            <input type="radio" id="no" name="delete_it" value="no">
            <label for="no">No</label>
        </div>
        <input type="submit">
    </form>
</div>

